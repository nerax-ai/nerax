{
  "name": "nerax-ai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "monoup build",
    "test": "bun run build && bun test",
    "lint": "bun run --filter '*' lint",
    "clean": "monoup clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "monoup": "^0.4.0",
    "prettier": "^3.2.5",
    "typescript": "^5.7.3"
  }
}
